.layout{display:flex;min-height:100vh}
.sidebar{width:260px;background:#1E3A5F;color:white;position:fixed;height:100vh;display:flex;flex-direction:column}
.logo{padding:1.5rem;font-size:1.3rem;font-weight:700;border-bottom:1px solid rgba(255,255,255,.1)}
nav{flex:1;padding:1rem 0}
.nav-item{display:block;padding:.75rem 1.5rem;color:rgba(255,255,255,.8);text-decoration:none}
.nav-item:hover,.nav-item.active{background:rgba(255,255,255,.1);color:white}
.main{margin-left:260px;flex:1;padding:2rem;background:#f8f9fa;min-height:100vh}
h1{color:#1E3A5F;margin-bottom:1.5rem}
.loading{text-align:center;padding:3rem;color:#666}
.empty{text-align:center;padding:3rem;color:#666;background:white;border-radius:12px}
.empty a{color:#1E3A5F;font-weight:600}
.enrollments{display:grid;grid-template-columns:repeat(auto-fill,minmax(350px,1fr));gap:1.5rem}
.enrollment-card{background:white;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.06);transition:transform .2s}
.enrollment-card:hover{transform:translateY(-3px)}
.card-cover{height:120px;background:linear-gradient(135deg,#1E3A5F,#4A90D9);display:flex;align-items:center;justify-content:center;font-size:3rem}
.card-body{padding:1.25rem}
.card-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:.5rem}
.card-header h3{color:#1E3A5F;margin:0;flex:1}
.status-badge{padding:.2rem .65rem;border-radius:10px;font-size:.75rem;font-weight:600;white-space:nowrap;margin-left:.5rem}
.status-active{background:#bee3f8;color:#2b6cb0}
.status-completed{background:#c6f6d5;color:#276749}
.status-abandoned{background:#fed7d7;color:#c53030}
.card-body p{color:#666;font-size:.9rem;margin-bottom:1rem}
.progress-section{margin-bottom:1rem}
.progress-label{display:flex;justify-content:space-between;font-size:.85rem;color:#555;margin-bottom:.4rem}
.progress-bar{height:8px;background:#e2e8f0;border-radius:4px}
.progress-fill{height:100%;background:#4A90D9;border-radius:4px;transition:width .5s}
.progress-fill.complete{background:#38a169}
.card-footer{display:flex;justify-content:space-between;align-items:center}
.enrolled-date{font-size:.8rem;color:#999}
.btn-continue{padding:.5rem 1.25rem;background:#1E3A5F;color:white;border-radius:6px;text-decoration:none;font-size:.9rem;font-weight:600}
.btn-continue:hover{background:#2d5080}